<!-- Classes Management Page -->
<div class="container-fluid py-4 classes-page edu-page">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center classes-page-header">
                <h1 class="h3 mb-0">
                    <i class="bi bi-people-fill text-primary me-2"></i>
                    Quản lý Lớp học
                </h1>
                <div class="d-flex gap-2 align-items-center classes-page-actions">
                    <div class="btn-group keep-horizontal-mobile" id="viewModeToggle" role="group">
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="gridViewBtn"
                            onclick="setClassViewMode('grid')" title="Dạng lưới">
                            <i class="bi bi-grid-3x3-gap-fill"></i>
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="tableViewBtn"
                            onclick="setClassViewMode('table')" title="Dạng bảng">
                            <i class="bi bi-list-ul"></i>
                        </button>
                    </div>
                    <button class="btn btn-primary" onclick="createNewClass()">
                        <i class="bi bi-plus-circle me-1"></i> Tạo Lớp mới
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tab Navigation - Modern Style -->
    <div class="class-tabs-container mb-4">
        <div class="class-tabs" role="tablist">
            <button class="class-tab active" id="active-tab" role="tab" aria-selected="true"
                onclick="filterClasses('active'); switchTab(this)">
                <i class="bi bi-book-half"></i>
                <span class="tab-label">Đang học</span>
                <span class="tab-count" id="activeClassCount">0</span>
            </button>
            <button class="class-tab" id="archived-tab" role="tab" aria-selected="false"
                onclick="filterClasses('archived'); switchTab(this)">
                <i class="bi bi-archive"></i>
                <span class="tab-label">Lưu trữ</span>
                <span class="tab-count archived" id="archivedClassCount">0</span>
            </button>
        </div>
    </div>

    <!-- Classes List View -->
    <div id="classes-list-view">
        <div id="classes-list" class="row">
            <!-- Will be populated by JavaScript -->
        </div>
    </div>

    <!-- Class Detail View -->
    <div id="class-detail-view" style="display: none;">
        <!-- Will be populated by JavaScript -->
    </div>
</div>




<script>
    function switchTab(tabEl) {
        document.querySelectorAll('.class-tab').forEach(t => t.classList.remove('active'));
        tabEl.classList.add('active');
    }

    // Load classes when data is ready
    window.addEventListener('app-data-ready', function () {
        if (typeof renderClassesList === 'function') {
            renderClassesList();
        }
    });
</script>
