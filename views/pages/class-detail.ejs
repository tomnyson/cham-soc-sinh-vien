                        <button type="button" class="btn btn-outline-secondary timer-quick-set" data-minutes="5">5
                            phút</button>
                        <button type="button" class="btn btn-outline-secondary timer-quick-set" data-minutes="10">10
                            phút</button>
                    </div>
                </div>

                <div class="mb-4">
