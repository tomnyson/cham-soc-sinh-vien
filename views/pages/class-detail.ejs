<div class="container-fluid py-4 class-detail-page edu-page" id="classDetailPage" data-class-id="<%= classData.classId %>">
    <div class="row align-items-center mb-4">
        <div class="col-md-8">
            <p class="text-muted mb-1">
                <a href="/classes" class="text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách lớp
                </a>
            </p>
            <h1 class="h3 mb-1 d-flex align-items-center gap-2">
                <i class="bi bi-people-fill text-primary"></i>
                <span id="classDetailName">
                    <%= classData.name %>
                </span>
            </h1>
            <p class="text-muted mb-0" id="classDetailDescription">
                <%= classData.description || 'Chưa có mô tả cho lớp học này.' %>
            </p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <div class="card shadow-sm border-0">
                <div class="card-body py-3">
                    <div class="small text-muted">Cập nhật lần cuối</div>
                    <div class="fw-semibold" id="classDetailUpdatedAt">
                        <% if (classData.updatedAt) { %>
                            <%= new Date(classData.updatedAt).toLocaleString('vi-VN') %>
                                <% } else { %>
                                    -
                                    <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4 class-detail-stats-row">
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-people"></i>
                </div>
                <h3 id="classDetailStudentCount">
                    <%= classData.students.length %>
                </h3>
                <p>Tổng sinh viên</p>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-clipboard-check"></i>
                </div>
                <h3 id="classDetailProfileName">
                    <% if (selectedProfileId) { %>
                        <%= (profiles.find(p=> p.profileId === selectedProfileId) || {}).name || 'Profile' %>
                            <% } else { %>
                                Chưa chọn
                                <% } %>
                </h3>
                <p>Profile điểm đang áp dụng</p>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-bar-chart-line"></i>
                </div>
                <h3 id="classDetailPassRate">0%</h3>
                <p>Tỷ lệ đạt</p>
            </div>
        </div>
    </div>

    <!-- Tools Row -->
    <div class="row g-3 mb-4 class-detail-tools-row">
        <!-- Lucky Wheel Button -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm" style="cursor: pointer;" data-bs-toggle="modal"
                data-bs-target="#luckyWheelModal">
                <div class="card-body d-flex align-items-center class-detail-tool-body">
                    <div>
                        <h5 class="mb-1"><i class="bi bi-arrow-repeat me-1"></i> Vòng Quay</h5>
                    </div>
                </div>
            </div>
        </div>
        <!-- Team Grouping Button -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm" style="cursor: pointer;" data-bs-toggle="modal"
                data-bs-target="#teamGroupModal">
                <div class="card-body d-flex align-items-center class-detail-tool-body">
                    <div>
                        <h5 class="mb-1"><i class="bi bi-diagram-3 me-1"></i> Chia Nhóm</h5>
                    </div>
                </div>
            </div>
        </div>
        <!-- Timer Button -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm" style="cursor: pointer;" data-bs-toggle="modal"
                data-bs-target="#timerModal">
                <div class="card-body d-flex align-items-center class-detail-tool-body">
                    <div>
                        <h5 class="mb-1"><i class="bi bi-stopwatch me-1"></i> Hẹn Giờ</h5>
                    </div>
                </div>
            </div>
        </div>
        <!-- Note Board Button -->
        <div class="col-12 col-sm-6 col-lg-3">
            <a href="/classes/<%= classData.classId %>/note" class="card h-100 border-0 shadow-sm text-decoration-none text-reset">
                <div class="card-body d-flex align-items-center class-detail-tool-body">
                    <div>
                        <h5 class="mb-1"><i class="bi bi-pencil-square me-1"></i> Note Bảng</h5>
                    </div>
                </div>
            </a>
        </div>
        <!-- Report Tool Button -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm" style="cursor: pointer;" data-bs-toggle="modal"
                data-bs-target="#reportToolModal">
                <div class="card-body d-flex align-items-center class-detail-tool-body">
                    <div>
                        <h5 class="mb-1"><i class="bi bi-journal-text me-1"></i> Báo Cáo</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end class-detail-profile-row">
                <div class="col-lg-6">
                    <label class="form-label fw-semibold text-muted">
                        <i class="bi bi-sliders me-1"></i> Chọn profile điểm cho lớp
                    </label>
                    <select id="classDetailProfileSelect" class="form-select">
                        <option value="">-- Chọn profile --</option>
                        <% profiles.forEach(profile=> { %>
                            <option value="<%= profile.profileId %>" <%=profile.profileId===selectedProfileId
                                ? 'selected' : '' %>>
                                <%= profile.name %>
                                    <% if (profile.isDefault) { %>
                                        (mặc định)
                                        <% } %>
                            </option>
                            <% }) %>
                    </select>
                    <small class="text-muted d-block mt-1">
                        Áp dụng profile điểm để xem và chỉnh sửa điểm thành phần của từng sinh viên.
                    </small>
                </div>
                <div class="col-lg-6 text-lg-end class-detail-action-col">
                    <button class="btn btn-outline-secondary me-2" onclick="window.location.href='/classes'">
                        <i class="bi bi-arrow-left-short me-1"></i> Quay lại danh sách
                    </button>
                    <!-- Share Link Button -->
                    <div class="btn-group me-2 keep-horizontal-mobile">
                        <button class="btn btn-outline-success" id="shareGradesBtn"
                            title="Chia sẻ link tra cứu điểm cho sinh viên">
                            <i class="bi bi-share me-1"></i> Share điểm
                        </button>
                        <button type="button" class="btn btn-outline-success dropdown-toggle dropdown-toggle-split"
                            data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="visually-hidden">Toggle Dropdown</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="#" id="copyShareLinkBtn">
                                    <i class="bi bi-clipboard me-2"></i> Copy link
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="#" id="openShareLinkBtn">
                                    <i class="bi bi-box-arrow-up-right me-2"></i> Mở trang tra cứu
                                </a>
                            </li>
                        </ul>
                    </div>
                    <button class="btn btn-outline-primary me-2" id="classDetailSendEmailBtn"
                        title="Gửi điểm và ghi chú qua email cho sinh viên">
                        <i class="bi bi-envelope-paper me-1"></i> Gửi email điểm
                    </button>
                    <button class="btn btn-primary" id="classDetailSaveBtn" disabled>
                        <i class="bi bi-save me-1"></i> Lưu thay đổi
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h5 class="mb-0 d-flex align-items-center gap-2">
                <i class="bi bi-table text-primary"></i>
                Bảng điểm thành phần
            </h5>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-primary-subtle text-primary" id="classDetailProfileSummary">-</span>
                <button class="btn btn-outline-primary btn-sm d-none" id="gradeTableCopySelectedBtn">
                    <i class="bi bi-clipboard-check me-1"></i>
                    Copy MSSV đã chọn (<span id="gradeTableCopySelectedCount">0</span>)
                </button>
                <!-- Column Visibility Toggle -->
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button"
                        id="columnVisibilityDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside"
                        aria-expanded="false" title="Ẩn/Hiện cột">
                        <i class="bi bi-eye me-1"></i> Cột hiển thị
                    </button>
                    <div class="dropdown-menu dropdown-menu-end p-2" id="columnVisibilityMenu"
                        style="min-width: 200px;">
                        <div class="dropdown-header small fw-semibold text-muted">Chọn cột hiển thị:</div>
                        <div id="columnVisibilityOptions">
                            <!-- Options will be populated dynamically -->
                        </div>
                        <div class="dropdown-divider"></div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-primary flex-grow-1" id="showAllColumnsBtn">
                                <i class="bi bi-eye me-1"></i> Hiện tất cả
                            </button>
                            <button class="btn btn-sm btn-outline-secondary flex-grow-1" id="hideAllColumnsBtn">
                                <i class="bi bi-eye-slash me-1"></i> Ẩn tất cả
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Search & Filter Bar -->
        <div class="border-bottom bg-light px-3 py-2">
            <div class="d-flex flex-wrap gap-2 align-items-center class-detail-filter-row">
                <div class="input-group input-group-sm flex-grow-1" style="max-width: 280px;">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" class="form-control" id="gradeSearchInput"
                        placeholder="Tìm theo tên hoặc MSSV...">
                </div>
                <select class="form-select form-select-sm shadow-none" id="gradeStatusFilter" style="max-width: 160px;">
                    <option value="all">Tất cả trạng thái</option>
                    <option value="pass">✓ Đạt</option>
                    <option value="fail">✗ Chưa đạt</option>
                </select>
                <select class="form-select form-select-sm shadow-none" id="gradeTextColFilter" style="max-width: 180px;" title="Lọc theo cột văn bản / nhóm">
                    <option value="">-- Lọc theo nhóm --</option>
                </select>
                <input type="text" class="form-control form-control-sm" id="gradeTextColValue" style="max-width: 160px;" placeholder="Giá trị lọc..." title="Nhập giá trị cần lọc trong cột đã chọn">
                <span class="small text-muted ms-auto" id="gradeFilterCount"></span>
            </div>
        </div>
        <div class="card-body p-0">
            <div id="classDetailEmptyState" class="text-center py-5 text-muted" style="display: none;">
                <i class="bi bi-info-circle fs-1 d-block mb-3"></i>
                Vui lòng chọn profile điểm để hiển thị bảng điểm và chỉnh sửa.
            </div>
            <div class="table-responsive" id="classDetailTableWrapper">
                <table class="table table-hover mb-0">
                    <thead id="classDetailTableHeader"></thead>
                    <tbody id="classDetailTableBody"></tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white d-flex justify-content-between flex-wrap gap-2">
            <div class="text-muted small">
                <i class="bi bi-info-circle me-1"></i>
                Điểm nhập trong khoảng 0 - 10. Tổng điểm sẽ tự động cập nhật.
            </div>
            <div class="d-flex flex-wrap gap-2 class-detail-footer-actions">
                <div class="d-flex align-items-center gap-2 class-detail-footer-item">
                    <input type="file" id="classDetailImportInput" accept=".xlsx,.xls" class="d-none" />
                    <button class="btn btn-outline-success btn-sm" id="classDetailImportBtn">
                        <i class="bi bi-upload me-1"></i> Nhập điểm Excel
                    </button>
                </div>
                <div class="d-flex align-items-center gap-2 class-detail-footer-item">
                    <input type="file" id="multiQuizImportInput" accept=".xlsx,.xls" class="d-none" />
                    <button class="btn btn-success btn-sm" id="multiQuizImportBtn"
                        title="Nhập điểm từ file có nhiều sheet Quiz/Lab">
                        <i class="bi bi-file-earmark-spreadsheet me-1"></i> Nhập Quiz/Lab (Nhiều sheet)
                    </button>
                </div>
                <div class="d-flex align-items-center gap-2 ms-1 class-detail-footer-item">
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" id="importOnlyEmpty" checked />
                        <label class="form-check-label small text-muted" for="importOnlyEmpty">
                            ko thêm 0 vào ô trống
                        </label>
                    </div>
                </div>
                <button class="btn btn-outline-success btn-sm" id="classDetailExportExcelBtn">
                    <i class="bi bi-file-earmark-excel me-1"></i> Xuất toàn bộ điểm (Excel)
                </button>
                <button class="btn btn-outline-dark btn-sm" id="syncGoogleSheetBtn" data-bs-toggle="modal"
                    data-bs-target="#syncGoogleSheetModal">
                    <i class="bi bi-google me-1"></i> Sync Google Sheet
                </button>
                <button class="btn btn-outline-primary btn-sm" id="classDetailResetBtn">
                    <i class="bi bi-arrow-counterclockwise me-1"></i> Hoàn tác thay đổi
                </button>
            </div>
        </div>
        <div class="px-3 pb-3">
            <div id="classDetailImportStatus" class="text-muted small"></div>
        </div>

        <!-- Quick Import Section -->
        <div class="card-footer bg-white border-top">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <h6 class="mb-0 d-flex align-items-center gap-2">
                    <i class="bi bi-lightning-charge text-warning"></i>
                    Nhập điểm nhanh
                </h6>
                <button class="btn btn-link btn-sm p-0" type="button" data-bs-toggle="collapse"
                    data-bs-target="#quickImportSection">
                    <i class="bi bi-chevron-down"></i>
                </button>
            </div>
            <div class="collapse" id="quickImportSection">
                <div class="row g-3">
                    <div class="col-lg-4">
                        <label class="form-label small fw-semibold">Chọn cột điểm:</label>
                        <select id="quickImportColumn" class="form-select form-select-sm">
                            <option value="">-- Chọn cột --</option>
                        </select>
                    </div>
                    <div class="col-lg-8">
                        <label class="form-label small fw-semibold">
                            Nhập điểm (mỗi dòng: <code>MSSV điểm</code>):
                        </label>
                        <textarea id="quickImportText" class="form-control form-control-sm font-monospace" rows="4"
                            placeholder="VD:&#10;PK02986 7.5&#10;PK02987 8.0&#10;PK02988 9.5"></textarea>
                        <div class="text-muted small mt-1">
                            <i class="bi bi-info-circle me-1"></i>
                            Hỗ trợ định dạng: <code>MSSV điểm</code> hoặc <code>MSSV, điểm</code> hoặc
                            <code>MSSV    điểm</code>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center class-detail-quick-row">
                            <div class="d-flex align-items-center gap-3 class-detail-quick-meta">
                                <div id="quickImportStatus" class="text-muted small"></div>
                                <div class="form-check mb-0">
                                    <input class="form-check-input" type="checkbox" id="quickImportOnlyEmpty" checked />
                                    <label class="form-check-label small text-muted" for="quickImportOnlyEmpty">
                                        Chỉ điền ô trống
                                    </label>
                                </div>
                            </div>
                            <div class="d-flex gap-2 class-detail-quick-actions">
                                <button class="btn btn-outline-secondary btn-sm" id="fillZeroBtn"
                                    title="Điền 0 vào tất cả ô trống của cột đã chọn">
                                    <i class="bi bi-0-circle me-1"></i> Điền 0 vào ô trống
                                </button>
                                <button class="btn btn-warning btn-sm" id="quickImportBtn">
                                    <i class="bi bi-lightning-charge me-1"></i> Áp dụng điểm
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Statistics Chart Card -->
    <div class="card shadow-sm border-0 mt-4" id="statsChartCard">
        <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h5 class="mb-0 d-flex align-items-center gap-2">
                <i class="bi bi-bar-chart-fill text-primary"></i>
                Thống kê phổ điểm
            </h5>
            <div class="d-flex align-items-center gap-2 class-detail-stats-controls">
                <label class="small text-muted mb-0 text-nowrap fw-semibold">Xem theo:</label>
                <select class="form-select form-select-sm shadow-none border" id="chartComponentSelect"
                    style="width: auto; min-width: 180px;">
                    <option value="TOTAL">Tổng điểm (có bonus)</option>
                </select>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="statsChartToggleBtn"
                    aria-expanded="true" title="Ẩn/Hiện thống kê">
                    <i class="bi bi-chevron-up me-1"></i><span class="toggle-label">Ẩn</span>
                </button>
            </div>
        </div>
        <div class="card-body" id="statsChartBody">
            <div class="row g-4 align-items-center">
                <div class="col-12 col-lg-8">
                    <div style="position: relative; height: 320px;">
                        <canvas id="gradeChartCanvas"></canvas>
                    </div>
                </div>
                <div class="col-12 col-lg-4">
                    <div class="row g-3">
                        <div class="col-6 col-lg-12">
                            <div class="border rounded p-3 text-center">
                                <div class="text-muted small mb-1">Tổng sinh viên</div>
                                <div class="fw-bold fs-4 text-primary" id="statTotalStudents">—</div>
                            </div>
                        </div>
                        <div class="col-6 col-lg-12">
                            <div class="border rounded p-3 text-center">
                                <div class="text-muted small mb-1">Điểm trung bình</div>
                                <div class="fw-bold fs-4 text-info" id="statAverageScore">—</div>
                            </div>
                        </div>
                        <div class="col-6 col-lg-12">
                            <div class="border rounded p-3 text-center">
                                <div class="text-muted small mb-1">Tỷ lệ Đạt</div>
                                <div class="fw-bold fs-4 text-success" id="statPassRate">—</div>
                            </div>
                        </div>
                        <div class="col-6 col-lg-12">
                            <div class="border rounded p-3 text-center">
                                <div class="text-muted small mb-1">Tỷ lệ Trượt</div>
                                <div class="fw-bold fs-4 text-danger" id="statFailRate">—</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Lucky Wheel Modal -->
<div class="modal fade" id="luckyWheelModal" tabindex="-1" aria-labelledby="luckyWheelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content lucky-wheel-modal">
            <div class="modal-header lucky-wheel-header">
                <h5 class="modal-title" id="luckyWheelModalLabel">
                    <i class="bi bi-bullseye me-2"></i> Vòng Quay May Mắn
                </h5>
                <div class="ms-auto d-flex align-items-center gap-3">
                    <div class="lucky-wheel-counter" title="Còn lại / Tổng">
                        <i class="bi bi-people-fill"></i>
                        <span id="wheelRemaining">0</span>
                        <span class="lucky-wheel-counter-sep">/</span>
                        <span id="wheelTotalStudents"><%= classData.students.length %></span>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
            </div>
            <div class="modal-body p-0">
                <div class="row g-0 lucky-wheel-body">
                    <!-- Wheel column -->
                    <div class="col-lg-7 lucky-wheel-stage">
                        <div class="wheel-container position-relative">
                            <canvas id="wheelCanvas" width="380" height="380"></canvas>
                            <div class="wheel-pointer" aria-hidden="true">
                                <i class="bi bi-caret-down-fill"></i>
                            </div>
                            <button id="spinWheelBtn" type="button" class="wheel-spin-btn">
                                <span class="wheel-spin-btn-label">SPIN</span>
                            </button>
                        </div>

                        <!-- Winner -->
                        <div id="wheelWinner" class="lucky-wheel-winner d-none" role="status" aria-live="polite">
                            <div class="lucky-wheel-winner-trophy">
                                <i class="bi bi-trophy-fill"></i>
                            </div>
                            <div class="lucky-wheel-winner-info">
                                <div class="lucky-wheel-winner-label">Người trúng</div>
                                <div class="lucky-wheel-winner-name" id="winnerName">—</div>
                                <div class="lucky-wheel-winner-mssv" id="winnerMssv"></div>
                            </div>
                        </div>

                        <!-- Empty state when all students drawn -->
                        <div id="wheelEmptyState" class="lucky-wheel-empty d-none" role="status">
                            <div class="lucky-wheel-empty-icon">
                                <i class="bi bi-stars"></i>
                            </div>
                            <div class="lucky-wheel-empty-title">Đã quay hết tất cả sinh viên</div>
                            <div class="lucky-wheel-empty-desc">Bấm "Đặt lại phiên" để bắt đầu lượt mới.</div>
                            <button type="button" class="btn btn-warning mt-3" id="resetWheelBtnEmpty">
                                <i class="bi bi-arrow-counterclockwise me-1"></i> Đặt lại phiên
                            </button>
                        </div>
                    </div>

                    <!-- Side panel -->
                    <div class="col-lg-5 lucky-wheel-side">
                        <div class="lucky-wheel-tabs btn-group w-100" role="tablist">
                            <button class="btn lucky-wheel-tab active" data-tab-target="upcoming" type="button">
                                <i class="bi bi-list-ol me-1"></i>
                                Sắp quay
                                <span class="badge bg-light text-dark ms-1" id="shuffledCount">0</span>
                            </button>
                            <button class="btn lucky-wheel-tab" data-tab-target="history" type="button">
                                <i class="bi bi-clock-history me-1"></i>
                                Lịch sử
                                <span class="badge bg-light text-dark ms-1" id="historyCount">0</span>
                            </button>
                        </div>

                        <div class="lucky-wheel-side-actions">
                            <button id="shuffleWheelBtn" type="button" class="btn btn-outline-primary btn-sm flex-grow-1">
                                <i class="bi bi-shuffle me-1"></i> Xáo trộn
                            </button>
