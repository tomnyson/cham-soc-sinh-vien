        font-weight: 700;
        font-variant-numeric: tabular-nums;
        letter-spacing: 0.04em;
        color: #1e293b;
        transition: color 0.2s ease;
    }

    /* Copy column button styles */
    .copy-column-btn,
    .chart-column-btn {
        color: #6c757d;
        transition: color 0.2s ease;
    }

    .copy-column-btn:hover {
        color: #0d6efd;
    }

    .chart-column-btn:hover {
        color: #764ba2;
    }

    .class-detail-student-meta {
        font-size: 0.75rem;
        color: #64748b;
