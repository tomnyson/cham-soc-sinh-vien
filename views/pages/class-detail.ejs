    }

    @media (max-width: 430px) {
        .class-detail-page {
            padding-left: 0;
            padding-right: 0;
        }

        .class-detail-stats-row .col-6 {
            padding-left: 0.375rem;
            padding-right: 0.375rem;
        }

        .class-detail-stats-row h3 {
            font-size: 1.2rem;
        }

        .class-detail-tools-row .col-12 {
            padding-left: 0.375rem;
            padding-right: 0.375rem;
        }

        .class-detail-tool-body {
            min-height: 50px;
        }

        .class-detail-tool-body h5 {
            font-size: 0.95rem;
        }

        .class-detail-stats-controls label,
        .class-detail-stats-controls #chartComponentSelect,
        .class-detail-stats-controls #statsChartToggleBtn {
            width: 100%;
            margin-left: 0 !important;
        }

        .class-detail-action-col > button {
            width: 100%;
        }

        .class-detail-action-col > .btn-group {
            width: 100%;
        }

        .class-detail-action-col > .btn-group .btn:first-child {
            flex: 1 1 auto;
        }

        #classDetailTableHeader th,
        #classDetailTableBody td {
            position: static !important;
            left: auto !important;
        }

        #classDetailTableHeader th:nth-child(3)::after,
        #classDetailTableBody td:nth-child(3)::after {
            display: none;
        }

        #classDetailTableHeader th:nth-child(3),
        #classDetailTableBody td:nth-child(3) {
            border-right: none;
        }

        #classDetailTableWrapper {
            max-height: none;
        }

        #classDetailTableWrapper table {
            font-size: 0.79rem;
        }

        #classDetailTableWrapper th,
        #classDetailTableWrapper td {
            padding: 0.5rem 0.45rem;
            white-space: nowrap;
        }

        #luckyWheelModal .modal-dialog,
        #teamGroupModal .modal-dialog,
        #scoreChartModal .modal-dialog,
        #chartStudentListModal .modal-dialog,
        #shareQrModal .modal-dialog,
        #syncGoogleSheetModal .modal-dialog,
        #timerModal .modal-dialog {
            margin: 0.45rem;
        }

        #luckyWheelModal .modal-body,
        #teamGroupModal .modal-body,
        #scoreChartModal .modal-body,
        #chartStudentListModal .modal-body,
        #shareQrModal .modal-body,
        #syncGoogleSheetModal .modal-body,
        #timerModal .modal-body {
            max-height: calc(100vh - 150px);
            overflow-y: auto;
        }
    }
</style>

