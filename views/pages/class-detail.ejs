                    <div class="row g-2 align-items-end">
                        <div class="col-5">
                            <label class="form-label small text-muted">Phút</label>
                            <input id="timerCustomMin" type="number" min="0" max="180" class="form-control" value="0">
                        </div>
                        <div class="col-5">
                            <label class="form-label small text-muted">Giây</label>
                            <input id="timerCustomSec" type="number" min="0" max="59" class="form-control" value="0">
                        </div>
                        <div class="col-2 d-grid">
                            <button id="timerSetCustomBtn" type="button" class="btn btn-outline-primary"
                                title="Đặt thời gian">
                                <i class="bi bi-check2"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button id="timerStartPauseBtn" type="button" class="btn btn-primary flex-fill">
                        <i class="bi bi-play-fill me-1"></i> Bắt đầu
                    </button>
                    <button id="timerResetBtn" type="button" class="btn btn-outline-danger">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
                    </button>
                </div>

                <div class="form-check form-switch mt-3">
                    <input class="form-check-input" type="checkbox" id="timerSoundToggle" checked>
                    <label class="form-check-label small text-muted" for="timerSoundToggle">
                        Bật âm báo khi hết giờ
                    </label>
                </div>

                <audio id="timerAudioAlarm" preload="auto"></audio>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<!-- Score Chart Modal -->
<div class="modal fade" id="scoreChartModal" tabindex="-1" aria-labelledby="scoreChartModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header text-white" style="background: linear-gradient(135deg, #FF6C00 0%, #E65100 100%);">
                <h5 class="modal-title" id="scoreChartModalLabel">
