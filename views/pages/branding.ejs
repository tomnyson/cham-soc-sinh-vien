<div class="container-fluid py-4 branding-page edu-page" id="brandingPage">
    <div class="branding-hero mb-4">
        <div>
            <span class="branding-kicker">
                <i class="bi bi-stars"></i>
                Brand Studio
            </span>
            <h1 class="h3 mb-1">Nhận diện trang chia sẻ điểm</h1>
            <p class="text-muted mb-0">
                Logo, subtext và màu chính sẽ áp dụng cho header hệ thống và trang tra cứu điểm công khai.
            </p>
        </div>
        <div class="branding-hero-chip">
            <i class="bi bi-shield-check"></i>
            PNG/JPG/WEBP · tối đa 500KB
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 branding-control-card">
                <div class="card-body p-4">
                    <div class="branding-section-header">
                        <div>
                            <h2>Logo trung tâm</h2>
                            <p>Ưu tiên logo nền trong suốt, ngang hoặc vuông đều được.</p>
                        </div>
                        <button class="btn btn-outline-secondary btn-sm" id="brandingClearLogoBtn" type="button">
                            <i class="bi bi-x-circle me-1"></i> Bỏ file
                        </button>
                    </div>

                    <label class="branding-upload-zone" id="brandingLogoDropzone" for="brandingLogoInput">
                        <input class="visually-hidden" type="file" id="brandingLogoInput"
                            accept="image/png,image/jpeg,image/webp">
                        <span class="branding-upload-preview">
                            <img id="brandingUploadLogoPreview"
                                src="/images/logo.svg"
                                alt="Logo đang chọn">
                        </span>
                        <span class="branding-upload-copy">
                            <strong>Thả logo vào đây hoặc bấm để chọn file</strong>
                            <small id="brandingLogoMeta">Chỉ nhận PNG/JPG/WEBP, tối đa 500KB.</small>
                        </span>
                        <span class="branding-upload-action">
                            <i class="bi bi-cloud-arrow-up"></i>
                        </span>
                    </label>

                    <div class="branding-form-grid mt-4">
                        <div>
                            <label for="brandingSubtextInput" class="form-label fw-semibold">Subtext</label>
                            <div class="input-with-icon">
                                <i class="bi bi-type"></i>
                                <input type="text" class="form-control" id="brandingSubtextInput" maxlength="80"
                                    placeholder="FPT Polytechnic">
                            </div>
                        </div>
                        <div>
                            <label for="brandingPrimaryColorInput" class="form-label fw-semibold">Màu primary</label>
                            <div class="branding-color-control">
                                <input type="color" class="form-control form-control-color"
                                    id="brandingPrimaryColorPicker" value="#FF6C00" title="Chọn màu">
                                <input type="text" class="form-control text-uppercase" id="brandingPrimaryColorInput"
                                    value="#FF6C00" maxlength="7" placeholder="#FF6C00">
                            </div>
                        </div>
                    </div>

                    <div class="branding-live-strip mt-4">
                        <div>
                            <span>Trạng thái</span>
                            <strong id="brandingReadiness">Sẵn sàng lưu</strong>
                        </div>
                        <div>
                            <span>Màu đang dùng</span>
                            <strong id="brandingColorReadout">#FF6C00</strong>
                        </div>
                        <div>
                            <span>Logo</span>
                            <strong id="brandingLogoReadout">Mặc định</strong>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button class="btn btn-primary" id="brandingSaveBtn" type="button">
                            <i class="bi bi-save me-1"></i> Lưu Branding
                        </button>
                        <button class="btn btn-outline-secondary" id="brandingResetBtn" type="button">
                            <i class="bi bi-arrow-counterclockwise me-1"></i> Reset mặc định
                        </button>
                    </div>

                    <div class="branding-status mt-3" id="brandingStatus" role="status" aria-live="polite"></div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0 h-100 branding-preview-card">
                <div class="card-body p-4">
                    <div class="branding-section-header mb-3">
                        <div>
                            <h2>Preview nhanh</h2>
                            <p>Mô phỏng header của trang share điểm.</p>
                        </div>
                    </div>
                    <div class="branding-preview" id="brandingPreview" style="--branding-preview-color:#FF6C00;">
                        <div class="branding-preview-header">
                            <div class="branding-preview-logo-shell">
                                <img id="brandingLogoPreview"
                                    src="/images/logo.svg"
                                    alt="Logo preview">
                            </div>
                            <h3><i class="bi bi-mortarboard-fill"></i> Tra cứu điểm sinh viên</h3>
                            <p id="brandingSubtextPreview">FPT Polytechnic</p>
                        </div>
                        <div class="branding-preview-body">
                            <div>
                                <span>MSSV</span>
                                <strong>PK00001</strong>
                            </div>
                            <div>
                                <span>Điểm cuối</span>
                                <strong>8.4</strong>
                            </div>
                            <button type="button">Xem kết quả</button>
                        </div>
                    </div>
                    <p class="small text-muted mb-0 mt-3">
                        Sau khi lưu, logo cũng được cập nhật cho sidebar/header của app.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="module" src="<%- assetPath('/js/pages/branding.js') %>"></script>
