<%
/**
 * Grade Entry Dashboard page.
 *
 * Expected locals:
 *   - classes: [{classId, name, studentCount}]
 *   - selectedClassId: string
 *   - dashboard: { classData, profile, students, summary } | null
 */
const summary = (dashboard && dashboard.summary) ? dashboard.summary : { total: 0, passed: 0, atRisk: 0, failed: 0, passRate: 0 };
const classNameDisplay = (dashboard && dashboard.classData) ? dashboard.classData.name : '';
%>

<div class="container-fluid py-4 dashboard-page edu-page" id="dashboardPage" data-selected-class="<%= selectedClassId %>">

    <!-- Page header -->
    <div class="row align-items-center mb-4">
        <div class="col-md-8">
            <h1 class="h3 mb-1 d-flex align-items-center gap-2">
                <i class="bi bi-clipboard-data text-primary"></i>
                Bảng nhập điểm &amp; trạng thái sinh viên
            </h1>
            <p class="text-muted mb-0">
                Nhập điểm trực tiếp trên bảng. Hệ thống tự động tính tổng và phân loại Đạt / Nguy cơ / Chưa đạt.
            </p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <label for="dashboardClassSelect" class="form-label small text-muted mb-1">Lớp đang xem</label>
            <select class="form-select" id="dashboardClassSelect">
                <% if (!classes || classes.length === 0) { %>
                    <option value="">Chưa có lớp nào</option>
                <% } else { %>
                    <% classes.forEach(function(cls) { %>
                        <option value="<%= cls.classId %>" <%= cls.classId === selectedClassId ? 'selected' : '' %>>
                            <%= cls.name %> (<%= cls.studentCount %> sinh viên)
                        </option>
                    <% }); %>
                <% } %>
            </select>
        </div>
    </div>

    <!-- Stats cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-people"></i>
                </div>
                <h3 id="dashboardStatTotal"><%= summary.total %></h3>
                <p>Tổng sinh viên</p>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-check-circle"></i>
                </div>
                <h3 id="dashboardStatPassed"><%= summary.passed %></h3>
                <p>Đạt</p>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <h3 id="dashboardStatAtRisk"><%= summary.atRisk %></h3>
                <p>Nguy cơ</p>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                    <i class="bi bi-x-circle"></i>
                </div>
                <h3 id="dashboardStatFailed"><%= summary.failed %></h3>
                <p>Chưa đạt</p>
            </div>
        </div>
    </div>

    <!-- Toolbar: filters + class title -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div>
                <div class="small text-muted">Lớp</div>
                <div class="h5 mb-0" id="dashboardClassName">
                    <%= classNameDisplay || 'Chưa chọn lớp' %>
                </div>
            </div>
            <div class="btn-group" role="group" aria-label="Lọc trạng thái">
                <input type="radio" class="btn-check" name="dashboardFilter" id="dashboardFilterAll" value="all" checked>
                <label class="btn btn-outline-primary" for="dashboardFilterAll">Tất cả</label>

                <input type="radio" class="btn-check" name="dashboardFilter" id="dashboardFilterPassed" value="passed">
                <label class="btn btn-outline-success" for="dashboardFilterPassed">Đạt</label>

                <input type="radio" class="btn-check" name="dashboardFilter" id="dashboardFilterAtRisk" value="at-risk">
                <label class="btn btn-outline-warning" for="dashboardFilterAtRisk">Nguy cơ</label>

                <input type="radio" class="btn-check" name="dashboardFilter" id="dashboardFilterFailed" value="failed">
                <label class="btn btn-outline-danger" for="dashboardFilterFailed">Chưa đạt</label>
            </div>
        </div>
    </div>

    <!-- Save indicator -->
    <div class="alert alert-success py-2 px-3 d-none mb-3" id="dashboardSaveIndicator" role="status" aria-live="polite">
        <i class="bi bi-cloud-check me-2"></i>
        <span id="dashboardSaveMessage">Đã lưu</span>
    </div>

    <!-- Student grade table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0" id="dashboardTableContainer">
            <%- include('../partials/studentList', { dashboard: dashboard }) %>
        </div>
    </div>
</div>

<script src="/js/pages/dashboard.js" defer></script>
