<!DOCTYPE html>
<html lang="vi" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title || 'FPT Polytechnic - Hệ thống quản lý điểm' %>
    </title>

    <script>
        (function () {
            try {
                var savedTheme = localStorage.getItem('studentCareTheme');
                var prefersDark = window.matchMedia
                    && window.matchMedia('(prefers-color-scheme: dark)').matches;
                var theme = savedTheme === 'light' || savedTheme === 'dark'
                    ? savedTheme
                    : (prefersDark ? 'dark' : 'light');
                document.documentElement.setAttribute('data-theme', theme);
            } catch (error) {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Sora:wght@500;600;700;800&display=swap"
        rel="stylesheet">

    <!-- External libraries -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

    <!-- Custom CSS -->
    <link rel="stylesheet" href="<%- assetPath('/css/style.css') %>">
    <link rel="stylesheet" href="<%- assetPath('/css/reliability.css') %>">
    <link rel="stylesheet" href="<%- assetPath('/css/auth.css') %>">
    <link rel="icon" href="data:,">

    <%- include('../partials/head-extra') %>
</head>

<body>
    <%- include('../partials/sidebar') %>
    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

        <!-- Main Content -->
        <div class="main-content">
            <%- include('../partials/header') %>
                <%- include('../partials/mobile-nav') %>

                    <!-- Page Content -->
                    <div class="page-content">
                        <div id="page-content">
                            <%- body %>
                        </div>
                    </div>
        </div>

        <%- include('../partials/modals') %>

            <% const layoutBranding = (typeof branding !== 'undefined' && branding)
                ? branding
                : {
                    logoDataUrl: '/images/logo.svg',
                    subtext: 'FPT Polytechnic',
                    primaryColor: '#FF6C00'
                }; %>
            <script>
                window.__APP_BRANDING__ = <%- JSON.stringify(layoutBranding).replace(/</g, '\\u003c') %>;
            </script>

            <% if (typeof initialData !== 'undefined' && initialData) { %>
                <script>
                    window.__INITIAL_SERVER_DATA__ = <%- JSON.stringify(initialData).replace(/</g, '\\u003c') %>;
                </script>
            <% } %>

            <% if (typeof user !== 'undefined' && user) { %>
                <script>
                    window.__CURRENT_USER__ = <%- JSON.stringify(user).replace(/</g, '\\u003c') %>;
                </script>
            <% } %>

                    <%- include('../partials/scripts') %>
                        <%- include('../partials/scripts-extra') %>
</body>

</html>
