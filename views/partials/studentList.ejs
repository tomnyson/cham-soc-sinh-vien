<%
/**
 * Student grade list partial.
 *
 * Expects `dashboard` in locals. When `dashboard` is null, renders an empty
 * state. Component scores are editable inline; the surrounding page wires up
 * the change handler to call `PUT /api/classes/:classId/student/:mssv/grade`.
 */
const data = (typeof dashboard !== 'undefined' && dashboard) ? dashboard : null;
const profile = data && data.profile ? data.profile : null;
const weights = profile && profile.weights ? profile.weights : {};
const columns = Object.keys(weights);
%>

<% if (!data) { %>
    <div class="alert alert-info mb-0">
        <i class="bi bi-info-circle me-2"></i>
        Hãy chọn một lớp ở bộ lọc bên trên để xem bảng điểm.
    </div>
<% } else if (!data.students || data.students.length === 0) { %>
    <div class="alert alert-warning mb-0">
        <i class="bi bi-exclamation-triangle me-2"></i>
        Lớp <strong><%= data.classData.name %></strong> chưa có sinh viên nào.
    </div>
<% } else { %>
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0" id="dashboardStudentTable"
               data-class-id="<%= data.classData.classId %>">
            <thead class="table-light">
                <tr>
                    <th style="width: 48px;">#</th>
                    <th>MSSV</th>
                    <th>Họ và tên</th>
                    <% columns.forEach(function(col) { %>
                        <th class="text-center" data-column="<%= col %>">
                            <%= col %>
                            <small class="text-muted d-block">
                                Trọng số <%= weights[col] %>%
                            </small>
                        </th>
                    <% }); %>
                    <th class="text-center">Tổng</th>
                    <th class="text-center">Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                <% data.students.forEach(function(student, idx) { %>
                    <tr class="dashboard-student-row" data-mssv="<%= student.mssv %>" data-status="<%= student.status %>">
                        <td><%= idx + 1 %></td>
                        <td><strong class="copyable-mssv" data-mssv="<%= student.mssv %>" title="Click để copy MSSV" style="cursor:pointer;"><%= student.mssv %> <i class="bi bi-clipboard text-muted" style="font-size:0.65rem;"></i></strong></td>
                        <td>
                            <%= student.name %>
                            <% if (student.email) { %>
                                <small class="text-muted d-block"><%= student.email %></small>
                            <% } %>
                        </td>
                        <% columns.forEach(function(col) {
                            const value = student.grades && student.grades[col] !== undefined && student.grades[col] !== null
                                ? Number(student.grades[col])
                                : '';
                        %>
                            <td class="text-center">
                                <input type="number" min="0" max="10" step="0.01"
                                       class="form-control form-control-sm grade-input mx-auto"
                                       style="max-width: 90px;"
                                       data-mssv="<%= student.mssv %>"
                                       data-column="<%= col %>"
                                       value="<%= value %>"
                                       aria-label="<%= col %> của <%= student.name %>">
                            </td>
                        <% }); %>
                        <td class="text-center fw-bold dashboard-final-total">
                            <%= (typeof student.finalTotal === 'number' ? student.finalTotal : student.totalScore || 0).toFixed(2) %>
                        </td>
                        <td class="text-center">
                            <% if (student.status === 'passed') { %>
                                <span class="badge badge-pass dashboard-status-badge">✓ Đạt</span>
                            <% } else if (student.status === 'at-risk') { %>
                                <span class="badge bg-warning text-dark dashboard-status-badge">⚠ Nguy cơ</span>
                            <% } else { %>
                                <span class="badge badge-fail dashboard-status-badge">✗ Chưa đạt</span>
                            <% } %>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
<% } %>
