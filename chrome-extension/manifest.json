{
  "manifest_version": 3,
  "name": "Tool Cham Soc SV - GV Poly Scanner",
  "version": "1.0.0",
  "description": "Scan student information from gv.poly.edu.vn and reveal masked phone fields before reading.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://gv.poly.edu.vn/student/student_infomation*",
        "https://gv.poly.edu.vn/student/student_information*"
      ],
      "js": ["student-info-content.js"],
      "run_at": "document_idle"
    }
  ]
}
